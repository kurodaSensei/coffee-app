rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isOwner() {
      return request.auth != null && resource.data.userId == request.auth.uid;
    }

    function isAuthenticatedCreate() {
      return request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    function isSharedWithMe() {
      return request.auth != null
        && resource.data.sharedWith is list
        && request.auth.uid in resource.data.sharedWith;
    }

    function isFriendshipParticipant() {
      return request.auth != null
        && request.auth.uid in resource.data.uids;
    }

    // User-owned collections (allow shared read for items with sharedWith array)
    match /roasters/{docId} {
      allow read: if isOwner();
      allow create: if isAuthenticatedCreate();
      allow update, delete: if isOwner();
    }

    match /coffees/{docId} {
      allow read: if isOwner() || isSharedWithMe();
      allow create: if isAuthenticatedCreate();
      allow update, delete: if isOwner();
    }

    match /tastings/{docId} {
      allow read: if isOwner() || isSharedWithMe();
      allow create: if isAuthenticatedCreate();
      allow update, delete: if isOwner();
    }

    match /recipes/{docId} {
      allow read: if isOwner() || isSharedWithMe();
      allow create: if isAuthenticatedCreate();
      allow update, delete: if isOwner();
    }

    match /wishlist/{docId} {
      allow read: if isOwner();
      allow create: if isAuthenticatedCreate();
      allow update, delete: if isOwner();
    }

    // User preferences: doc id equals user uid
    match /userPreferences/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Users directory: anyone authenticated can look up, only owner writes
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Friendships: both participants can read, either can write if they are participants
    match /friendships/{friendshipId} {
      allow read: if isFriendshipParticipant();
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.uids
        && request.resource.data.status == 'pending'
        && request.resource.data.initiatedBy == request.auth.uid;
      allow update: if isFriendshipParticipant();
      allow delete: if isFriendshipParticipant();
    }
  }
}
